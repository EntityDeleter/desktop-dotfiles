{
    "$schema": "https://opencode.ai/config.json",
    "server": {
        "port": 28282,
        "hostname": "localhost",
        "mdns": false,
        "mdnsDomain": "opencode.local",
        "cors": ["https://arch-desktop.stern-adelie.ts.net"]
    },
    "tools": {
        "write": true,
        "bash": true
    },
    "provider": {
        "llama.cpp": {
            "npm": "@ai-sdk/openai-compatible",
            "name": "llama.cpp",
            "options": {
                "baseURL": "http://100.69.242.6:11434/v1",
                "apiKey": "{file:/home/sudar/.config/opencode/apikey.txt}"
            },
            "models": {
                "gpt-oss-20b-mxfp4": {
                    "id": "gpt-oss-20b-mxfp4",
                    "name": "gpt oss 20b mxfp4",
                    "family": "gptoss",
                    "attachment": false,
                    "reasoning": true,
                    "temperature": true,
                    "tool_call": true,
                    "interleaved": true,
                    "modalities": {
                        "output": ["text"],
                        "input": ["text"]
                    }
                },
                "GLM-4.7-Flash-REAP-23B-A3B-Q5_K_M-tools": {
                    "id": "GLM-4.7-Flash-REAP-23B-A3B-Q5_K_M-tools",
                    "name": "GLM 4.7 Flash REAP 23B A3B Q5_K_M",
                    "family": "glm4moelite",
                    "attachment": false,
                    "reasoning": true,
                    "temperature": true,
                    "tool_call": true,
                    "interleaved": true,
                    "modalities": {
                        "output": ["text"],
                        "input": ["text"]
                    }
                },
                "gemma-4-26B-A4B-it-UD-Q5_K_M": {
                    "id": "gemma-4-26B-A4B-it-UD-Q5_K_M",
                    "name": "gemma 4 26B A4B it UD Q5_K_M",
                    "family": "gemma4",
                    "attachment": false,
                    "reasoning": true,
                    "temperature": true,
                    "tool_call": true,
                    "interleaved": true,
                    "modalities": {
                        "output": ["text"],
                        "input": ["text"]
                    }
                },
                "nvidia_Nemotron-Cascade-2-30B-A3B-Q5_K_M": {
                    "id": "nvidia_Nemotron-Cascade-2-30B-A3B-Q5_K_M",
                    "name": "nvidia_Nemotron Cascade 2 30B A3B Q5_K_M",
                    "family": "nemotron_h_moe",
                    "attachment": false,
                    "reasoning": true,
                    "temperature": true,
                    "tool_call": true,
                    "interleaved": true,
                    "modalities": {
                        "output": ["text"],
                        "input": ["text"]
                    }
                },
                "Qwen3.6-35B-A3B-UD-Q5_K_M-tools": {
                    "id": "Qwen3.6-35B-A3B-UD-Q5_K_M-tools",
                    "name": "Qwen3.6 35B A3B UD Q5_K_M",
                    "family": "qwen35moe",
                    "attachment": false,
                    "reasoning": true,
                    "temperature": true,
                    "tool_call": true,
                    "interleaved": true,
                    "modalities": {
                        "output": ["text"],
                        "input": ["text"]
                    }
                }
            }
        }
    },
    "default_agent": "build",
    "mcp": {
        "DeepWiki": {
            "type": "remote",
            "url": "https://mcp.deepwiki.com/mcp",
            "enabled": true
        },
        "BrowserOS": {
            "type": "remote",
            "url": "http://127.0.0.1:9000/mcp",
            "enabled": true
        }
    },
    "experimental": {
        "batch_tool": true,
        "continue_loop_on_deny": true,
        "mcp_timeout": 1000
    },
    "username": "EntityDeletr",
    "plugin": [
        "cc-safety-net",
        "@tarquinen/opencode-dcp@latest",
        "opencode-power-pack@git+https://github.com/waybarrios/opencode-power-pack.git",
        "superpowers@git+https://github.com/obra/superpowers.git",
        "opencode-handoff",
        "@warp-dot-dev/opencode-warp@0.1.5"
    ]
}
